# Dependencies
node_modules/

# Vite build output
dist/
dist-ssr/

# Local env files
.env
.env.local
.env.*.local

# Editor & OS
.vscode/
.DS_Store
Thumbs.db

# Playwright browser cache (large binaries, re-downloaded by each dev)
# Remove this line if you want to commit the browser for offline use
# ~/.cache/ms-playwright is the default path — no repo entry needed

# Persistent Playwright browser profile (large, machine-specific, contains session cookies)
.browser-profile/

# Exported browser cookies — may contain auth tokens, never commit
maptap-cookies.json

# Logs
*.log
npm-debug.log*
